
// hawtio reuses the broker's LDAPLogin realm — the SAME org.apache.activemq.jaas.LDAPLoginModule,
// so a hawtio login authenticates against LDAP exactly like the broker's web console.
// The ##### TOKEN ##### placeholders are substituted from env by docker-entrypoint.sh at startup.
LDAPLogin {
  org.apache.activemq.jaas.LDAPLoginModule required
    debug=true
    initialContextFactory=com.sun.jndi.ldap.LdapCtxFactory
    connectionURL="ldap://##### LDAP_HOST #####:##### LDAP_PORT #####"
    connectionUsername="##### LDAP_CONN_USER #####"
    connectionPassword="##### LDAP_CONN_USER_PWD #####"
    connectionProtocol=""
    authentication=simple
    userBase="##### LDAP_USER_BASE #####"
    userRoleName=admins
    userSearchMatching="(uid={0})"
    userSearchSubtree=false
    roleBase="##### LDAP_ROLE_BASE #####"
    roleName=cn
    roleSearchMatching="(member=uid={1})"
    roleSearchSubtree=true;
};
