{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Jetty jars pinned in the ActiveMQ Dockerfile and scripts/set-env.sh",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)set-env\\.sh$/"
      ],
      "matchStrings": [
        "JETTY_VER\\s*[=:]\\s*\"?(?<currentValue>[0-9][^\"\\s]+)\"?"
      ],
      "depNameTemplate": "org.eclipse.jetty:jetty-util",
      "datasourceTemplate": "maven"
    }
  ],
  "packageRules": [
    {
      "description": "ActiveMQ 6.2.6 bundles Jetty 11.0.26; JETTY_VER is a reference pin (6.x ships jetty-jaas, so no overlay jar). Major Jetty bumps (12+) are a manual migration tracked in CLAUDE.md",
      "matchDatasources": ["maven"],
      "matchPackageNames": ["org.eclipse.jetty:jetty-util"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
