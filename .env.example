# Committed source-of-truth defaults for operator-tunable values.
# Copy to `.env` (gitignored) to override locally; e2e/scripts source this
# file first, then `.env`. Demo credentials below are NOT secrets — they are
# {SHA} hashes of "admin" seeded into the LDIF fixtures.

# --- ActiveMQ broker ---
ACTIVEMQ_VER=5.19.6
ACTIVEMQ_CONSOLE_HOST=localhost
ACTIVEMQ_CONSOLE_PORT=8161
ACTIVEMQ_OPENWIRE_PORT=61616

# --- LDAP backends ---
LDAP_HOST=localhost
LDAP_PORT=389
LDAPS_PORT=636
APACHEDS_PORT=10389

# --- Demo credentials (NOT secrets) ---
LDAP_ADMIN_USER=admin
LDAP_ADMIN_PASSWORD=admin
DEMO_USER=user
DEMO_USER_PASSWORD=admin
LDAP_BASE_DN=dc=activemq,dc=apache,dc=org

# --- Container names (compose service/container names) ---
ACTIVEMQ_CONTAINER=activemq
OPENLDAP_CONTAINER=openldap

# --- e2e harness tunables ---
COMPOSE_FILE=5.19.6/docker-compose.yml
E2E_READY_TIMEOUT_SECONDS=120
E2E_POLL_INTERVAL_SECONDS=2
